# 环境变量配置文件示例
# 复制此文件为 .env 并填入你的 API 密钥

# ========== GLM-4.6 配置（智谱AI）==========
# 获取地址：https://open.bigmodel.cn/
# 免费额度：¥25（约 6,250 个动画）
ZHIPU_API_KEY=your_zhipu_api_key_here

# 默认使用的 GLM 模型
# glm-4-flash: 极速模式 (¥0.1/百万tokens) - 推荐
# glm-4-air: 高性能模式 (¥0.5/百万tokens)
# glm-4-plus: 旗舰模式 (¥0.5/百万tokens)
# glm-4-0520: 标准模式 (¥0.5/百万tokens)
GLM_MODEL_DEFAULT=glm-4-air

# ========== DeepSeek 配置（可选，复杂任务备用）==========
# 获取地址：https://platform.deepseek.com/
# 免费额度：¥10
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ========== 本地模型配置（可选）==========
# LOCAL_MODEL_PATH=/path/to/model
# USE_LOCAL_MODEL=false

# ========== 动画生成配置 ===========
# 输出目录
ANIMATION_OUTPUT_DIR=./output/animations
LATEX_OUTPUT_DIR=./output/latex

# 模型选择策略
# auto: 根据复杂度自动选择（推荐）
# glm_only: 仅使用 GLM
# deepseek_only: 仅使用 DeepSeek
MODEL_SELECTION_STRATEGY=auto

# 成本控制（每日预算，单位：元）
DAILY_BUDGET=10.0

# ========== 质量控制 ===========
# 启用代码验证
ENABLE_CODE_VALIDATION=true

# 失败重试次数
MAX_RETRIES=2

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/animation_generator.log
