ARG NODE_IMAGE=node:22-bookworm-slim
ARG PYTHON_IMAGE=python:3.12-slim

FROM ${NODE_IMAGE} AS plugin-builder

WORKDIR /workspace

COPY package.json package-lock.json ./
COPY packages ./packages
COPY plugins ./plugins
COPY vendor ./vendor
COPY frontend ./frontend
COPY tools ./tools

RUN rm -f package-lock.json && npm install --include=dev --include=optional --no-audit --no-fund --package-lock=false
RUN node tools/build-active-plugins.mjs

FROM ${PYTHON_IMAGE} AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8000 \
    DATABASE_PATH=/app/data/aha_tutor.db \
    PLUGINS_DIR=/app/plugins

WORKDIR /app

COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/app ./app
COPY backend/migrate_add_node_id.py ./migrate_add_node_id.py
COPY data ./data
COPY --from=plugin-builder /workspace/plugins ./plugins

EXPOSE 8000

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
