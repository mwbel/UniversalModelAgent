# Copy this file to .env on the server, then fill in real values.
# Do not commit real API keys.

LLM_API_KEY=replace-with-your-llm-api-key
LLM_BASE_URL=https://yunwu.ai/v1
LLM_MODEL=gemini-3.1-flash-lite

# For local Docker: http://localhost
# For a server: http://your-server-ip or https://your-domain
ALLOWED_ORIGINS=http://localhost

PORT=8000
WEB_PORT=80
DATABASE_PATH=/app/data/aha_tutor.db
PLUGINS_DIR=/app/plugins

AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
AGENT_DEFAULT_TEMPERATURE=0.7

# Optional: override base images when Docker Hub or a configured registry mirror is unavailable.
# Examples:
# NODE_IMAGE=docker.io/library/node:22-bookworm-slim
# PYTHON_IMAGE=docker.io/library/python:3.12-slim
# NGINX_IMAGE=docker.io/library/nginx:1.27-alpine
NODE_IMAGE=node:22-bookworm-slim
PYTHON_IMAGE=python:3.12-slim
NGINX_IMAGE=nginx:1.27-alpine
